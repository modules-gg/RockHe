# ============================================
# RockHe — GiMi 0.1 Environment Configuration
# ============================================

# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control!

# ============================================
# MODEL PATHS (Local / Self-hosted only)
# ============================================

# Path to your local model weights (GGUF, ONNX, PyTorch, etc.)
MODEL_PATH=

# Model architecture / loader type
# Options: llama-cpp | transformers | onnx | custom
MODEL_BACKEND=

# Specific model file (if directory contains multiple)
MODEL_FILENAME=

# ============================================
# API SERVER
# ============================================

API_HOST=
API_PORT=
API_DEBUG=

CORS_ORIGINS=

# ============================================
# GiMi ENGINE SETTINGS
# ============================================

MAX_TOKENS=
TEMPERATURE=
PERSONA=

# Context window size (in tokens)
CONTEXT_WINDOW=

# ============================================
# HARDWARE / GPU
# ============================================

# GPU layers to offload (0 = CPU only, -1 = all layers)
GPU_LAYERS=

# Device: cuda | cpu | mps | rocm
DEVICE=

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_RPM=
